# ================================
# .gitignore cho course-projects
# Java / Maven / NetBeans / Web
# ================================

# --- Maven / Build output ---
target/
build/
out/
bin/
dist/

# --- Compiled class & jar ---
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*

# --- IDE: NetBeans ---
nbproject/private/
nbbuild/
nbdist/
.nb-gradle/
nb-configuration.xml

# --- IDE: IntelliJ IDEA ---
.idea/
*.iml
*.iws
*.ipr

# --- IDE: Eclipse ---
.classpath
.project
.settings/
.metadata/

# --- IDE: VSCode ---
.vscode/

# --- Logs ---
*.log
logs/

# --- OS files ---
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# --- Temp / backup ---
*.tmp
*.bak
*.swp
*~

# --- Node / Frontend (nếu có) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Python (nếu có) ---
__pycache__/
*.py[cod]
*.egg-info/
venv/
.venv/

# --- Sensitive ---
*.env
.env
.env.local
secrets.properties
application-local.properties

# --- Database dumps ---
*.sql.bak
*.dump

# --- Git backup (tao boi nuclear-push.ps1) ---
.git.backup/
.git.backup-*/
*.git.backup

